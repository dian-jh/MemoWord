{
  "openapi": "3.1.1",
  "info": {
    "title": "AiService.API",
    "description": "AI chat and session history API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://localhost:50846"
    },
    {
      "url": "http://localhost:50848"
    }
  ],
  "paths": {
    "/ai/sessions/{sessionId}/messages": {
      "post": {
        "tags": [
          "AiSessionMessages"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostSessionMessageRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PostSessionMessageRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PostSessionMessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfSendSessionMessageResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfSendSessionMessageResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfSendSessionMessageResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "AiSessionMessages"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfListOfAiChatMessageDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfListOfAiChatMessageDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResultOfListOfAiChatMessageDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AiChatMessageDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "HttpResultOfListOfAiChatMessageDto": {
        "type": "object",
        "properties": {
          "code": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/AiChatMessageDto"
            }
          }
        }
      },
      "HttpResultOfSendSessionMessageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SendSessionMessageResponse"
              }
            ]
          }
        }
      },
      "PostSessionMessageRequest": {
        "required": [
          "content"
        ],
        "type": "object",
        "properties": {
          "content": {
            "maxLength": 4000,
            "minLength": 1,
            "type": "string"
          }
        }
      },
      "SendSessionMessageResponse": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "userMessage": {
            "$ref": "#/components/schemas/AiChatMessageDto"
          },
          "assistantMessage": {
            "$ref": "#/components/schemas/AiChatMessageDto"
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "直接输入 JWT Token（带或不带 Bearer 前缀均可）",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "AiSessionMessages"
    }
  ]
}