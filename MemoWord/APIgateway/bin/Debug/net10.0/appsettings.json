{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "word-service-route": {
        "ClusterId": "word-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/word/{**remainder}"
        },
        "CorsPolicy": "AllowArkTS"
      },
      "ai-service-route": {
        "ClusterId": "ai-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/ai/{**remainder}"
        },
        "CorsPolicy": "AllowArkTS"
      },
      "auth-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**remainder}"
        },
        "CorsPolicy": "AllowArkTS"
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/v1/users/{**remainder}"
        },
        "CorsPolicy": "AllowArkTS"
      }
    },
    "Clusters": {
      "word-cluster": {
        "Destinations": {
          "local-machine": {
            "Address": "http://wordservice-webapi"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "local-machine": {
            "Address": "http://aiservice-webapi"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "friend-pc": {
            "Address": "http://2bf2dc5e.r21.cpolar.top"
          }
        }
      }
    }
  }
}
